generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENTE
  ADMIN

  @@map("Role")
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum TreeStatus {
  PURCHASED
  PLANTED
  GROWING
  HEALTHY
  NEEDS_ATTENTION
  MATURE
}

model User {
  id               String            @id @default(cuid())
  name             String
  username         String?           @unique
  email            String            @unique
  passwordHash     String
  role             UserRole          @default(CLIENTE)
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  purchases        TreePurchase[]
  carbonFootprints CarbonFootprint[]
  adminUploadLogs  AdminUploadLog[]
  uploadedPhotos    TreePhoto[]
}

model Role {
  id          String   @id @default(cuid())
  name        UserRole @unique
  description String
  createdAt   DateTime @default(now())

  @@map("AppRole")
}

model TreeProduct {
  id                   String         @id @default(cuid())
  name                 String
  species              String
  description          String
  price                Decimal        @db.Decimal(10, 2)
  imageUrl             String
  estimatedKgCo2PerYear Float
  stock                Int
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  purchases            TreePurchase[]
}

model TreePurchase {
  id              String            @id @default(cuid())
  userId          String
  treeProductId   String
  quantity        Int               @default(1)
  unitPrice       Decimal           @db.Decimal(10, 2)
  total           Decimal           @db.Decimal(10, 2)
  status          TreeStatus        @default(PURCHASED)
  plantedAt       DateTime?
  location        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  treeProduct     TreeProduct       @relation(fields: [treeProductId], references: [id])
  payment         Payment?
  trackingEvents  TreeTracking[]
  qrCode          QRCode?
  carbonFootprint CarbonFootprint?
}

model Payment {
  id             String        @id @default(cuid())
  treePurchaseId String        @unique
  provider       String        @default("SIMULATED")
  reference      String        @unique
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("COP")
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  treePurchase   TreePurchase  @relation(fields: [treePurchaseId], references: [id], onDelete: Cascade)
}

model TreeTracking {
  id             String        @id @default(cuid())
  treePurchaseId String
  eventDate      DateTime      @default(now())
  description    String
  location       String?
  status         TreeStatus
  createdAt      DateTime      @default(now())
  treePurchase   TreePurchase  @relation(fields: [treePurchaseId], references: [id], onDelete: Cascade)
  photos         TreePhoto[]
}

model TreePhoto {
  id             String        @id @default(cuid())
  treeTrackingId String
  imageUrl       String
  caption        String?
  uploadedById   String?
  createdAt      DateTime      @default(now())
  treeTracking   TreeTracking  @relation(fields: [treeTrackingId], references: [id], onDelete: Cascade)
  uploadedBy     User?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
}

model QRCode {
  id             String       @id @default(cuid())
  treePurchaseId String       @unique
  code           String       @unique
  imageUrl       String?
  createdAt      DateTime     @default(now())
  treePurchase   TreePurchase @relation(fields: [treePurchaseId], references: [id], onDelete: Cascade)
}

model CarbonFootprint {
  id                 String       @id @default(cuid())
  userId             String
  treePurchaseId     String?      @unique
  estimatedKgCo2     Float
  accumulatedKgCo2   Float
  calculationDate    DateTime     @default(now())
  notes              String?
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  treePurchase       TreePurchase? @relation(fields: [treePurchaseId], references: [id], onDelete: Cascade)
}

model AdminUploadLog {
  id           String   @id @default(cuid())
  adminId      String
  fileName     String
  fileUrl      String
  entityType   String
  entityId     String?
  notes        String?
  uploadedAt   DateTime @default(now())
  admin        User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
}
