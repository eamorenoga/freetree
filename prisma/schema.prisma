generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENTE
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

enum UserTreeStatus {
  ASIGNADO
  SEMBRADO
  EN_CRECIMIENTO
  MADURO
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role           @default(CLIENTE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  userTrees     UserTree[]
  carbonRecords CarbonRecord[]
}

model Tree {
  id           String      @id @default(cuid())
  species      String
  description  String
  price        Decimal     @db.Decimal(10, 2)
  imageUrl     String
  estimatedCo2 Float
  stock        Int
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]
  userTrees    UserTree[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  total     Decimal     @db.Decimal(10, 2)
  status    OrderStatus @default(COMPLETADA)
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  treeId    String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tree      Tree    @relation(fields: [treeId], references: [id])
}

model UserTree {
  id             String           @id @default(cuid())
  userId         String
  treeId         String
  location       String
  plantedAt      DateTime?
  status         UserTreeStatus   @default(ASIGNADO)
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tree           Tree             @relation(fields: [treeId], references: [id])
  trackingEvents TrackingEvent[]
}

model TrackingEvent {
  id          String   @id @default(cuid())
  userTreeId  String
  title       String
  description String
  imageUrl    String?
  eventDate   DateTime @default(now())
  userTree    UserTree @relation(fields: [userTreeId], references: [id], onDelete: Cascade)
}

model CarbonRecord {
  id              String   @id @default(cuid())
  userId          String
  treesCount      Int
  estimatedKgCo2  Float
  notes           String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
